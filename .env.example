# Greenish Environment Variables
# Copy this file to .env and fill in your values

# Core
SECRET_KEY=your-secret-key-here-generate-with-python
DEBUG=True
ALLOWED_HOSTS=*

# Production: set these when deploying
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# PostgreSQL (only needed when DEBUG=False)
# DB_NAME=greenish
# DB_USER=greenish
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432